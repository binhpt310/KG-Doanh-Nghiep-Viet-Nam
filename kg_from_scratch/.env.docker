# Nguồn cấu hình duy nhất cho Docker / kg-app (Compose env_file + COPY vào image).
# Neo4j (mạng nội bộ Docker)
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password123
NEO4J_DATABASE=neo4j

# vLLM — OpenAI-compatible API trên host (không có /v1 ở đây)
LLM_BACKEND=openai
LLM_BASE_URL=http://host.docker.internal:9061
VLLM_BASE_URL=http://host.docker.internal:9061
MODEL_NAME=qwen3-14b
